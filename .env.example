# =============================================================
# AI Recruiter — environment template
# Copy to .env and fill in. Never commit .env to git.
# =============================================================

# ---- Application ----
APP_ENV=dev                          # dev | staging | prod
APP_LOG_LEVEL=INFO
APP_TIMEZONE=Europe/Kyiv
APP_BASE_URL=https://api.recruiter-ai.example.com

# ---- Anthropic / Claude ----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL_CHEAP=claude-haiku-4-5-20251001

# ---- OpenAI (backup, cheap classifications) ----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ---- Deepgram (STT) ----
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=multi              # auto-detect uk/ru/en
DEEPGRAM_ENDPOINTING_MS=300

# ---- ElevenLabs (TTS) ----
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=                 # uk voice id, e.g. "EXAVITQu4vr4xnSDxMaL"
ELEVENLABS_MODEL=eleven_flash_v2_5

# ---- Vapi.ai (voice orchestration) ----
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_WEBHOOK_SECRET=
VAPI_PHONE_NUMBER_ID=                # Vapi phoneNumber UUID (any provider)

# ---- Telephony BYOC ----
# Pick one: vapi (free US, no intl), telnyx, twilio.
# Twilio/Telnyx require identity verification for UA outbound.
TELEPHONY_PROVIDER=telnyx            # vapi | telnyx | twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TELNYX_API_KEY=
TELNYX_PHONE_NUMBER=
RINGOSTAT_API_KEY=
RINGOSTAT_PROJECT_ID=

# ---- KeyCRM ----
KEYCRM_API_TOKEN=                    # NEVER paste in chat. Add via sops or VPS shell.
KEYCRM_FUNNEL_ID=
KEYCRM_BASE_URL=https://openapi.keycrm.app/v1
KEYCRM_WEBHOOK_SECRET=

# ---- work.ua API (official, FREE inbound + paid resume search) ----
WORKUA_EMPLOYER_EMAIL=
WORKUA_EMPLOYER_PASSWORD=
WORKUA_SCRAPE_DAILY_LIMIT=50
WORKUA_PROXY_URL=                    # residential proxy
# Comma-separated whitelist of job_id — poll only these vacancies. Empty = all.
WORKUA_ALLOWED_VACANCY_IDS=

# ---- Pluggable job board providers (stubs — fill keys to enable) ----
# robota.ua: partner API token (request via partner-api@robota.ua). Optional —
# if you don't have API access, use the Playwright scraper with email+password.
ROBOTAUA_API_TOKEN=
ROBOTAUA_EMPLOYER_EMAIL=
ROBOTAUA_EMPLOYER_PASSWORD=
# Comma-separated whitelist — scrape only these vacancy ids' Відгуки tab. Empty = all.
ROBOTAUA_ALLOWED_VACANCY_IDS=
# Jooble: meta-search for vacancies, not candidate responses
JOOBLE_API_KEY=
# OLX Jobs (UA): partner OAuth2 — request via partner-jobs@olx.ua
OLX_JOBS_CLIENT_ID=
OLX_JOBS_CLIENT_SECRET=

# ---- Telegram (DAILY REPORT BOT — separate from any other bots) ----
TG_REPORT_BOT_TOKEN=
TG_REPORT_CHAT_ID=                   # channel/group/user id
TG_REPORT_HOUR=9                     # 9:00 Europe/Kyiv
TG_REPORT_MINUTE=0

# ---- Storage (audio recordings) ----
S3_ENDPOINT=https://...hetzner.cloud
S3_BUCKET=recruiter-ai-recordings
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-central

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://recruiter:secret@db:5432/recruiter
# For local dev/tests can fallback to:
# DATABASE_URL=sqlite+aiosqlite:///./local.db

# ---- Matching / filters ----
MATCH_SCORE_THRESHOLD=0.65           # candidate must score >= to enter call queue
REGION_WHITELIST=Київська,Житомирська,Вінницька,Хмельницька,Тернопільська,Львівська,Івано-Франківська,Закарпатська,Чернівецька,Рівненська,Волинська,Черкаська
REGION_BLACKLIST=м. Київ,Суми,Сумська,Запоріжжя,Запорізька,Херсон,Херсонська,Донецька

# ---- Candidate profile filter (Менеджер продажу / Логіст) ----
PROFILE_AGE_MIN_F=23
PROFILE_AGE_MAX_F=42
PROFILE_AGE_MIN_M=23
PROFILE_AGE_MAX_M=40
PROFILE_AGE_MIN_WITH_EDU=22
PROFILE_REQUIRED_COUNTRY=UA
# Recent role check: in the last N years, candidate must have a sales-manager role
PROFILE_RECENT_ROLE_YEARS=3
# Resumes that "ended" around this year ± tolerance are an OK exception (war-pause)
PROFILE_WAR_PAUSE_YEAR=2022
PROFILE_WAR_PAUSE_TOLERANCE=1

# ---- Persona + vacancy defaults (Kozyr Trans) ----
AGENT_NAME=Єва
COMPANY_NAME=Kozyr Trans
COMPANY_PITCH=Наша компанія займається організацією вантажоперевезень як для приватних осіб, так і для підприємств.
DEFAULT_VACANCY_TITLE=Менеджер з продажу, логіст
DEFAULT_VACANCY_SALARY=30-65 тисяч гривень+ (залежить від навичок і результатів; на старті нижче під час навчання)
DEFAULT_VACANCY_SCHEDULE=повністю віддалена, 5-денний робочий день з 9:00 до 17:00, сб-нд вихідні
DEFAULT_VACANCY_BENEFITS=навчання, підтримка кураторів, тепла база, ліди надходять щодня

# ---- Call scheduling ----
CALL_SLOTS=09:00,11:00,13:00,15:00,17:00,19:00
CALL_MAX_ATTEMPTS=3
CALL_MAX_CONCURRENT=3
CALL_MAX_DURATION_SEC=420            # 7 min hard cap

# ---- Guardrails ----
GUARDRAIL_MAX_REPETITION=2
GUARDRAIL_MAX_FORBIDDEN_TOPIC=1
